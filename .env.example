# ============================================================================
# Website Generator environment configuration
# Copy to .env and fill in. Never commit .env.
# ============================================================================

# --- LLM providers --------------------------------------------------------
# Pipeline tries each provider in LLM_PROVIDERS order; first one with a valid
# key wins. Set ALLOW_MANUAL_LLM=1 to fall back to terminal paste-in when
# every provider fails.
LLM_PROVIDERS=gemini,openai,anthropic,groq,manual
ALLOW_MANUAL_LLM=0

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Web data / scraping --------------------------------------------------
FIRECRAWL_API_KEY=
PAGESPEED_API_KEY=
ARENA_ACCESS_TOKEN=

# --- Hosting --------------------------------------------------------------
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# --- Email (optional, for outreach phase) ---------------------------------
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# --- Google Sheets (optional, for lead tracking) --------------------------
GOOGLE_SHEETS_CREDENTIALS=./secrets/sheets-sa.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- Project metadata -----------------------------------------------------
PROJECT_BASE_URL=
